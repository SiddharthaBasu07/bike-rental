# Residuals
residuals = np.expm1(y_val) - np.expm1(val_pred_xgb)
axes[1, 0].scatter(np.expm1(val_pred_xgb), residuals, alpha=0.5)
axes[1, 0].axhline(y=0, color='r', linestyle='--')
