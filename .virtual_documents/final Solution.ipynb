# Actual vs Predicted
axes[0, 1].scatter(np.expm1(y_val), np.expm1(val_pred_xgb), alpha=0.5)
axes[0, 1].plot([0, np.expm1(y_val).max()], [0, np.expm1(y_val).max()], 'r--')
axes[0, 1].set_xlabel('Actual Count')
